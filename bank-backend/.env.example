PORT=4000

# Orki Connect backend URL — used to fetch JWKS for webhook signature verification
ORKI_JWKS_URL=http://localhost:3000/.well-known/jwks.json

# Alternatively, paste the Orki RS256 public key directly (PEM format)
# ORKI_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: shared secret if your Orki plan uses HMAC instead of RS256
# ORKI_WEBHOOK_SECRET=your_secret_here

# Orki Connect backend — used for session creation proxy
ORKI_BACKEND_URL=http://localhost:3000
ORKI_ORG_ACCESS_TOKEN=your_org_access_token_here
