# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=

# ─── JWT Keys (RS256) ─────────────────────────────────────────────────────────
# Paths to PEM files generated by: make setup
# Files live in .keys/ which is gitignored
JWT_PRIVATE_KEY=.keys/private.pem
JWT_PUBLIC_KEY=.keys/public.pem

# JWKS public key modulus/exponent (base64url) — used for /v1/webhooks/.well-known/jwks.json
# These are set automatically by: make setup
JWKS_PUBLIC_KEY_N=
JWKS_PUBLIC_KEY_E=

# ─── Blockchain RPC URLs ──────────────────────────────────────────────────────
SOLANA_CLUSTER=devnet
# SOLANA_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ─── Webhook ──────────────────────────────────────────────────────────────────
DEFAULT_WEBHOOK_URL=http://localhost:4000/webhook

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Compliance / Risk (Elliptic) ─────────────────────────────────────────────
# Leave blank to run in mock mode
# ELLIPTIC_API_KEY=your_elliptic_api_key
ELLIPTIC_MOCK=true

# ─── Exchange OAuth Adapters ──────────────────────────────────────────────────
BINANCE_CLIENT_ID=your_binance_client_id
BINANCE_CLIENT_SECRET=your_binance_client_secret
BINANCE_REDIRECT_URI=https://yourapp.com/oauth/binance/callback

COINBASE_CLIENT_ID=your_coinbase_client_id
COINBASE_CLIENT_SECRET=your_coinbase_client_secret
COINBASE_REDIRECT_URI=https://yourapp.com/oauth/coinbase/callback
