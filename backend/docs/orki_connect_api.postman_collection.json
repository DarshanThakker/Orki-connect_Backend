{
    "info": {
        "_postman_id": "77a8b417-eb6c-48f2-8961-c88f11d14849",
        "name": "Orki Connect API",
        "description": "Orki Connect B2B SDK Backend — UAE/MENA Fintech API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "OAuth",
            "item": [
                {
                    "name": "Issue Access Token",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"client_id\": \"your_client_id\",\n    \"client_secret\": \"your_client_secret\",\n    \"grant_type\": \"client_credentials\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/oauth/token",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "oauth",
                                "token"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Organization",
            "item": [
                {
                    "name": "Create Organization",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"organization_id\": \"org_123\",\n    \"client_id\": \"client_456\",\n    \"client_secret\": \"secret_789\",\n    \"webhook_url\": \"https://your-api.com/webhooks\",\n    \"config\": {}\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/v1/org",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "org"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Org Config",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{accessToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/v1/org/config",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "org",
                                "config"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Org Config",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{accessToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PATCH",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"supported_tokens\": [\"USDC\", \"USDT\"],\n    \"min_per_transaction\": 5\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/v1/org/config",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "org",
                                "config"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Connect Sessions",
            "item": [
                {
                    "name": "Create Session",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{accessToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"user_id\": \"user_01\",\n    \"deposit_address\": \"0x...\",\n    \"network\": \"ETHEREUM\",\n    \"token\": \"USDC\",\n    \"mode\": \"LITE\",\n    \"connection_type\": \"WALLET\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/v1/connect/sessions",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "connect",
                                "sessions"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Session",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{accessToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/v1/connect/sessions/:session_id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "connect",
                                "sessions",
                                ":session_id"
                            ],
                            "variable": [
                                {
                                    "key": "session_id",
                                    "value": "{{sessionId}}"
                                }
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Exchange OAuth",
            "item": [
                {
                    "name": "Authorize Redirect",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/v1/connect/oauth/authorize?exchange=coinbase&session_id={{sessionId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "connect",
                                "oauth",
                                "authorize"
                            ],
                            "query": [
                                {
                                    "key": "exchange",
                                    "value": "coinbase"
                                },
                                {
                                    "key": "session_id",
                                    "value": "{{sessionId}}"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "OAuth Callback",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/v1/connect/oauth/callback?exchange=coinbase&state={{sessionId}}&code=auth_code_here",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "connect",
                                "oauth",
                                "callback"
                            ],
                            "query": [
                                {
                                    "key": "exchange",
                                    "value": "coinbase"
                                },
                                {
                                    "key": "state",
                                    "value": "{{sessionId}}"
                                },
                                {
                                    "key": "code",
                                    "value": "auth_code_here"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Initiate Withdrawal",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{accessToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"session_id\": \"{{sessionId}}\",\n    \"amount\": \"100.0\",\n    \"token\": \"USDC\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/v1/connect/oauth/withdraw",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "v1",
                                "connect",
                                "oauth",
                                "withdraw"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Webhooks",
            "item": [
                {
